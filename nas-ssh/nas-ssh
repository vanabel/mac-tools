  dest="$(_nas_scp_dest_for_host "$NAS_ZERO_HOST" "$NAS_DEFAULT_REMOTE_DIR" "$dest_arg")"
  scp -pr -P "$NAS_ZERO_PORT" "$src" "$dest"
}

rsyncnas() {
  # Usage: rsyncnas <source_path> [user@host:/remote_path]
  # Default: ${NAS_ZERO_HOST}:${NAS_DEFAULT_REMOTE_DIR}
  local src="$1"
  local dest_arg="${2:-$NAS_DEFAULT_REMOTE_DIR}"

  if [[ "$src" == "-h" || "$src" == "--help" || "$src" == "--usage" || -z "$src" ]]; then
    echo "Usage: rsyncnas <source_path> [user@host:/remote_path]"
    echo "Default destination: ${NAS_ZERO_HOST}:${NAS_DEFAULT_REMOTE_DIR}"
    return 0
  fi

  if ! command -v rsync >/dev/null 2>&1; then
    echo "rsync not found in PATH" >&2
    return 1
  fi

  local dest
  dest="$(_nas_rsync_dest_for_host "$NAS_ZERO_HOST" "$NAS_DEFAULT_REMOTE_DIR" "$dest_arg")"
  rsync -avh \
    --iconv=UTF-8-MAC,UTF-8 \
    -e "ssh -p $NAS_ZERO_PORT $_nas_ssh_keepalive_opts" \
    --info=progress2 \
    --partial \
    "$src" "$dest"
}

