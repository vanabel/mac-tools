  local dest_arg="${2:-$NAS_DEFAULT_REMOTE_DIR}"

  if [[ "$src" == "-h" || "$src" == "--help" || "$src" == "--usage" || -z "$src" ]]; then
    echo "Usage: scpnaszero <source_path> [remote_dir]"
    echo "Default destination: ${NAS_ZERO_HOST}:${NAS_DEFAULT_REMOTE_DIR}"
