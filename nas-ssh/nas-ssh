  local dest
  dest="$(_nas_scp_dest_for_host "$NAS_LOCAL_HOST" "$NAS_DEFAULT_REMOTE_DIR" "$dest_arg")"
  scp -pr -P "$NAS_LOCAL_PORT" "$src" "$dest"
